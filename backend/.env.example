app_name=VideoParse API
debug=true
frontend_origin=http://127.0.0.1:5173
api_public_origin=http://127.0.0.1:8000

cleanup_interval_hours=6
cleanup_retention_hours=6

# Optional shared settings
user_agent=
proxy=

# Bilibili
bilibili_proxy=
bilibili_sessdata=
bilibili_bili_jct=
bilibili_dedeuserid=

# YouTube
youtube_cookies=
youtube_player_client=
youtube_po_token=
youtube_js_runtimes=
youtube_remote_components=

# Twitter / X
twitter_auth_token=
twitter_ct0=
twitter_cookies=

# Iwara
iwara_authorization=
iwara_cookies=
iwara_user_agent=

# Douyin fallback
douyin_fallback_enabled=true
douyin_fallback_api_base=https://tools.devresourcehub.com
douyin_fallback_analyze_path=/api/v1/douyin
douyin_fallback_timeout_seconds=20

# Telegram Bot
telegram_bot_token=
telegram_bot_api_base=http://127.0.0.1:8081
telegram_polling_enabled=true
telegram_update_mode=polling
telegram_webhook_url=
telegram_webhook_secret=
telegram_poll_timeout_seconds=20
telegram_poll_interval_seconds=2
telegram_file_timeout_seconds=600
telegram_sync_cache_max_mb=300
telegram_file_prefetch_enabled=false
telegram_local_file_source_prefix=
telegram_local_file_target_prefix=
telegram_allowed_chat_ids=

download_format=bestvideo*[height<=1080]+bestaudio/best[height<=1080]/best
merge_output_format=mp4
ffmpeg_location=

proxy_timeout_seconds=30
proxy_chunk_size=65536
proxy_max_connections=20
media_access_refresh_interval_seconds=300
media_access_log_aggregation_enabled=true
media_access_log_window_seconds=5
internal_media_redirect_header=
internal_media_redirect_root=
internal_media_redirect_prefix=
